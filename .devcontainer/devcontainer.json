{
  "name": "Nanocoder Sandbox",
  "build": {
    "dockerfile": "Dockerfile"
  },
  
  // Safeguard: Automatically forwards your local API keys into the container 
  // without hardcoding them into your repository's files.
  "containerEnv": {
    "OLLAMA_HOST": "http://qut-l1953034068.qut.edu.au:11434/v1"
  },

  // Networking: Allows Nanocoder inside the container to talk to an Ollama 
  // instance running locally on your host machine via 'host.docker.internal'
  "runArgs": [
    "--add-host=host.docker.internal:host-gateway",
    "--network=host",
    "--dns=131.181.127.32",
  ],

  "customizations": {
    "vscode": {
    }
  },

  // Run as the non-root 'node' user built into the base image for better safety
  "remoteUser": "node"
}